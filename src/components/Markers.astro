---
// Markers.astro — inline SVG glyph from the geometry-marker library (§2).
// Uses currentColor so callers control color via the surrounding text color.
// type: "arrow" (↗ external), "arrow-right" (→ internal), "arrow-down" (↓ download), "star" (featured).
interface Props {
  type: "arrow" | "arrow-right" | "arrow-down" | "star";
  size?: number;
}
const { type, size = 18 } = Astro.props;
---
{type === "arrow" && (
  <svg class="glyph" width={size} height={size} viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="3" stroke-linecap="square" />
  </svg>
)}
{type === "arrow-right" && (
  <svg class="glyph" width={size} height={size} viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M4 12h15M13 6l6 6-6 6" stroke="currentColor" stroke-width="3" stroke-linecap="square" />
  </svg>
)}
{type === "arrow-down" && (
  <svg class="glyph" width={size} height={size} viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M12 4v15M6 13l6 6 6-6" stroke="currentColor" stroke-width="3" stroke-linecap="square" />
  </svg>
)}
{type === "star" && (
  <svg class="glyph" width={size} height={size} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 1l2.6 6.8L21 8l-5 4.4L17.6 19 12 15.4 6.4 19 8 12.4 3 8l6.4-.2z" />
  </svg>
)}
