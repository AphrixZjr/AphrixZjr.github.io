---
// projects.astro (§4.3) — SectionHeader + single-column Card list (academic).
// Cards link externally; deterministic breaking-the-grid via breaks.css.
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Card from "../components/Card.astro";

const entries = (await getCollection("projects")).sort(
  (a, b) => (b.data.order ?? 0) - (a.data.order ?? 0)
);
---
<BaseLayout title="Projects — AphrixZjr">
  <!-- §10.2: clashing-color blotch texture margins behind the reading column -->
  <div class="texture-margins">
    <div class="page wrap-col">
      <SectionHeader index="01" label="Projects" title="Projects" />
      <div class="card-list">
        {entries.map((entry, i) => (
          <Card entry={entry} index={i} kind="project" />
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page { padding-block: var(--sp-8) var(--sp-9); }
  .card-list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-7);
  }
</style>
